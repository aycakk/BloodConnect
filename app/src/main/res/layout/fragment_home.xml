<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="homefragment"
            type="com.softwarengineering.bloodconnect.ui.fragments.HomeFragment" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintLayout"
            android:layout_width="416dp"
            android:layout_height="75dp"
            android:background="#DE143C"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:context=".ui.fragments.HomeFragment">

            <ImageButton
                android:id="@+id/button_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:layout_marginStart="17dp"
                android:layout_marginTop="17dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOME"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textColorLink="#FBFBFB"
                android:textSize="20sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.5" />

            <ImageButton
                android:id="@+id/notification"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="25dp"
                android:background="@null"
                android:scaleType="centerInside"
                android:src="@drawable/notifications"
                app:layout_constraintBottom_toBottomOf="parent
"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/privatechoose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="WELCOME TO BLOOD CONNECT"
            android:textColor="#F80202"
            android:textColorLink="#FBFBFB"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/constraintLayout" />

        <androidx.cardview.widget.CardView
            android:id="@+id/donorhistorycd"
            android:layout_width="160dp"
            android:layout_height="85dp"
            android:layout_marginTop="21dp"
            app:cardBackgroundColor="#D9D9E0"
            app:cardCornerRadius="16dp"
            app:layout_constraintEnd_toEndOf="@+id/viewbloodreguestcd"
            app:layout_constraintStart_toStartOf="@+id/viewbloodreguestcd"
            app:layout_constraintTop_toBottomOf="@+id/imageView6">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="32dp"
                    android:text="Nearly Donors"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@+id/imageButton_nearlydonors"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/imageButton_nearlydonors"
                    android:layout_width="36dp"
                    android:layout_height="43dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="20dp"
                    android:background="@null"
                    android:scaleType="centerInside"
                    android:src="@drawable/button_nearlydonors"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/vreatebloodrequestcd"
            android:layout_width="160dp"
            android:layout_height="85dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="21dp"
            app:cardBackgroundColor="#D9D9E0"
            app:cardCornerRadius="16dp"
            app:layout_constraintStart_toEndOf="@+id/donorhistorycd"
            app:layout_constraintTop_toBottomOf="@+id/imageView6">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textView3"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="24dp"
                    android:text="Donation Tracking"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@+id/image_Buttondonation"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/image_Buttondonation"
                    android:layout_width="38dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="16dp"
                    android:background="@null"
                    android:scaleType="centerInside"
                    android:src="@drawable/donation_tracking"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/viewbloodreguestcd"
            android:layout_width="160dp"
            android:layout_height="85dp"
            android:layout_marginStart="35dp"
            android:layout_marginTop="29dp"
            app:cardBackgroundColor="#D9D9E0"
            app:cardCornerRadius="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/donorhistorycd">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textView6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_marginTop="32dp"
                    android:text="Request Blood"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@+id/image_buttonrequest"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/image_buttonrequest"
                    android:layout_width="39dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="21dp"
                    android:background="@null"
                    android:scaleType="centerInside"
                    android:src="@drawable/blood_request"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/managebloodinventerycd"
            android:layout_width="160dp"
            android:layout_height="85dp"
            android:layout_marginTop="29dp"
            app:cardBackgroundColor="#D9D9E0"
            app:cardCornerRadius="16dp"
            app:layout_constraintEnd_toEndOf="@+id/vreatebloodrequestcd"
            app:layout_constraintStart_toStartOf="@+id/vreatebloodrequestcd"
            app:layout_constraintTop_toBottomOf="@+id/vreatebloodrequestcd">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textView5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="32dp"
                    android:text="Donate"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@+id/imageButton_donateunion"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageButton
                    android:id="@+id/imageButton_donateunion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="19dp"
                    android:background="@null"
                    android:src="@drawable/donate_union"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/hospitalBtn"
            android:clickable="true"
            android:focusable="true"
            android:layout_width="345dp"
            android:layout_height="90dp"
            android:layout_marginTop="29dp"
            app:cardBackgroundColor="#D9D9E0"
            app:cardCornerRadius="16dp"
            app:layout_constraintEnd_toEndOf="@+id/managebloodinventerycd"
            app:layout_constraintStart_toStartOf="@+id/viewbloodreguestcd"
            app:layout_constraintTop_toBottomOf="@+id/viewbloodreguestcd">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/textView7"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Hospitals and Blood Banks"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toEndOf="@+id/image_Buttonhospital"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/textView10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="80dp"
                    android:layout_marginEnd="12dp"
                    android:text="Discover the hospitals and bloodbanks closest
                    to you and contact them in case of urgent blood needs."
                    android:textSize="12sp"
                    android:ellipsize="end"
                    android:maxLines="3"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/image_Buttonhospital"
                    app:layout_constraintTop_toBottomOf="@+id/textView7" />

                <ImageButton
                    android:id="@+id/image_Buttonhospital"
                    android:focusable="false"
                    android:clickable="false"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="20dp"
                    android:background="@null"
                    android:scaleType="centerInside"
                    android:src="@drawable/hospital"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>



        <ImageView
            android:id="@+id/imageView6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:src="@drawable/hhospital"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/privatechoose" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>